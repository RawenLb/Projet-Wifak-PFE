      "type": "table",
      "targets": [
        {
          "datasource": { "type": "mysql", "uid": "mysql-wifak" },
          "rawSql": "SELECT declaration_id AS Declaration, action AS Action, statut_avant AS Avant, statut_apres AS Apres, effectue_par AS EffectuePar, date_action AS Date FROM wifak_validation.validation_logs ORDER BY date_action DESC LIMIT 15",
          "format": "table",
          "refId": "A"
