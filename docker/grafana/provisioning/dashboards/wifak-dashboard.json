      "type": "table",
      "targets": [
        {
          "datasource": { "type": "mysql", "uid": "mysql-wifak" },
          "rawSql": "SELECT statut AS Statut, COUNT(*) AS Nombre FROM wifak_validation.declarations GROUP BY statut ORDER BY Nombre DESC",
