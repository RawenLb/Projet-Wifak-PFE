      "type": "table",
      "targets": [
        {
          "datasource": { "type": "mysql", "uid": "mysql-wifak" },
          "rawSql": "SELECT d.id, dt.nom AS type_declaration, d.statut, d.periode, d.genere_par FROM wifak_validation.declarations d LEFT JOIN wifak_validation.declaration_types dt ON d.declaration_type_id = dt.id ORDER BY d.id DESC LIMIT 10",
