          "datasource": { "type": "mysql", "uid": "mysql-wifak" },
          "rawSql": "SELECT declaration_id AS Declaration, notification_type AS Type, recipient AS Destinataire, statut AS Statut, date_sent AS Date FROM wifak_notification.notification_logs ORDER BY date_sent DESC LIMIT 15",
          "format": "table",
          "refId": "A"
        }
      ]
    },
