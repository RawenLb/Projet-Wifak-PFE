# ══════════════════════════════════════════════════════════════
# Configuration ML Service — Banque Wifak BCT
# ══════════════════════════════════════════════════════════════

# ── Base de données MySQL ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
# FIX: doit correspondre à la datasource Spring Boot (wifak_PFE)
DB_NAME=wifak_PFE
DB_USER=root
DB_PASSWORD=

# validation-service a sa propre base (wifak_validation, port 8084)
VALIDATION_DB_NAME=wifak_validation

# ── API FastAPI ────────────────────────────────────────────────
ML_SERVICE_HOST=0.0.0.0
ML_SERVICE_PORT=8090

# ── URLs des autres microservices ──────────────────────────────
BCT_BACKEND_URL=http://localhost:8082
VALIDATION_SERVICE_URL=http://localhost:8084

# ── Modèles ML ────────────────────────────────────────────────
MODELS_DIR=./models/saved
RETRAIN_INTERVAL_HOURS=12
MIN_SAMPLES_FOR_TRAINING=10

# ── Seuils anomalies (BF15) ────────────────────────────────────
ANOMALY_CONTAMINATION=0.05
ANOMALY_Z_SCORE_THRESHOLD=3.0

# ── Seuils risque (BF16) ──────────────────────────────────────
RISK_HIGH_THRESHOLD=0.7
RISK_MEDIUM_THRESHOLD=0.4

# ── Clustering erreurs (BF17) ─────────────────────────────────
CLUSTER_N_CLUSTERS=8
CLUSTER_MIN_SAMPLES=3
