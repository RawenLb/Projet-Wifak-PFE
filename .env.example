# ══════════════════════════════════════════════════════════════
# Banque Wifak BCT — Environment Variables
# Copier ce fichier en .env et remplir les valeurs réelles
# ══════════════════════════════════════════════════════════════

# ┌─────────────────────────────────────────────────────────────┐
# │  PORTS (informatif — ne pas changer sauf conflit)           │
# └─────────────────────────────────────────────────────────────┘
# Keycloak          : 8081
# Authentification  : 8082
# Chat-Service      : 8083
# Workflow-Decl.    : 8084
# Jira-Service      : 8085
# Notification      : 8086
# API Gateway       : 8088
# ML Service        : 8090
# Eureka Server     : 8761
# Frontend          : 4200
# Prometheus        : 9090
# Grafana           : 3000
# MySQL             : 3306


# ┌─────────────────────────────────────────────────────────────┐
# │  MYSQL                                                      │
# │  Utilisé par : tous les microservices Spring Boot           │
# └─────────────────────────────────────────────────────────────┘
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=
MYSQL_USER=root
MYSQL_PASSWORD=

# Bases de données (créées automatiquement au démarrage)
DB_AUTH=wifak_PFE
DB_CHAT=wifak_chat
DB_WORKFLOW=wifak_validation
DB_NOTIFICATION=wifak_notification
DB_JIRA=wifak_jira


# ┌─────────────────────────────────────────────────────────────┐
# │  KEYCLOAK                                                   │
# │  Utilisé par : Gateway, Authentification, Chat,             │
# │               Workflow, Notification, Jira                  │
# └─────────────────────────────────────────────────────────────┘
KEYCLOAK_URL=http://localhost:8081
KEYCLOAK_REALM=bct-realm
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=rawene

# Client Keycloak pour l'administration (authentification-service)
KEYCLOAK_ADMIN_CLIENT_ID=bct-backend
KEYCLOAK_ADMIN_CLIENT_SECRET=UQIUjf1lHznBjmmdUlNleh8N9yMwzBaG

# Client frontend Keycloak (authentification-service)
KEYCLOAK_FRONTEND_CLIENT_ID=bct-frontend

# JWT (Gateway + tous les resource servers)
# Format : {KEYCLOAK_URL}/realms/{KEYCLOAK_REALM}
JWT_ISSUER_URI=http://localhost:8081/realms/bct-realm
JWT_JWK_SET_URI=http://localhost:8081/realms/bct-realm/protocol/openid-connect/certs


# ┌─────────────────────────────────────────────────────────────┐
# │  EUREKA                                                     │
# │  Utilisé par : tous les microservices Spring Boot           │
# └─────────────────────────────────────────────────────────────┘
EUREKA_URL=http://localhost:8761/eureka/


# ┌─────────────────────────────────────────────────────────────┐
# │  SÉCURITÉ INTER-SERVICES                                    │
# │  Utilisé par : Authentification, Chat, Workflow,            │
# │               Notification, Jira                            │
# └─────────────────────────────────────────────────────────────┘
INTERNAL_SECRET=wifak-internal-secret-2024


# ┌─────────────────────────────────────────────────────────────┐
# │  CORS / FRONTEND                                            │
# │  Utilisé par : tous les microservices Spring Boot           │
# └─────────────────────────────────────────────────────────────┘
ALLOWED_ORIGINS=http://localhost:4200


# ┌─────────────────────────────────────────────────────────────┐
# │  NOTIFICATION SERVICE — EMAIL (SMTP)                        │
# └─────────────────────────────────────────────────────────────┘
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=rawene.labaoui@gmail.com
# Gmail App Password (Paramètres → Sécurité → Mots de passe d'application)
MAIL_PASSWORD=vjjt srre beng aium

# Keycloak admin pour notification-service
NOTIFICATION_KEYCLOAK_ADMIN_USERNAME=admin
NOTIFICATION_KEYCLOAK_ADMIN_PASSWORD=rawene
NOTIFICATION_KEYCLOAK_ADMIN_CLIENT_ID=admin-cli


# ┌─────────────────────────────────────────────────────────────┐
# │  JIRA INTEGRATION SERVICE                                   │
# └─────────────────────────────────────────────────────────────┘
JIRA_BASE_URL=https://wifak-bct.atlassian.net
JIRA_PROJECT_KEY=BCT
JIRA_USER_EMAIL=rawene.labaoui@gmail.com
# Générer sur : https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=ATATT3xFfGF0UVSZvQVI2t9HROjHGkcwd4v_fwaRn-COM9ARnLL_yuskLYajF4Ah68fi5XEGzGsc7ZetuWkynScY3b4e1gyS5S9yAU1-GNIUQM2pINPUup7csQgycgvCoeXS_JvD_TAywtK2m5LoqEs21dIsvaS0gjMyioadlEo9P7qSS0XNHCY=F664B0C6

# IDs des transitions Jira (récupérables via GET /rest/api/3/issue/{key}/transitions)
JIRA_TRANSITION_TODO=10001
JIRA_TRANSITION_IN_PROGRESS=10002
JIRA_TRANSITION_VALIDEE=10003
JIRA_TRANSITION_REJETEE=10004
JIRA_TRANSITION_ENVOYEE=2


# ┌─────────────────────────────────────────────────────────────┐
# │  ML SERVICE (Python / FastAPI)                              │
# └─────────────────────────────────────────────────────────────┘
ML_SERVICE_HOST=0.0.0.0
ML_SERVICE_PORT=8090

# Base de données ML (même MySQL)
ML_DB_HOST=localhost
ML_DB_PORT=3306
ML_DB_NAME=wifak_PFE
ML_DB_USER=root
ML_DB_PASSWORD=
ML_VALIDATION_DB_NAME=wifak_validation

# URLs des microservices appelés par le ML
ML_BCT_BACKEND_URL=http://localhost:8082
ML_VALIDATION_SERVICE_URL=http://localhost:8084

# Modèles sauvegardés
ML_MODELS_DIR=./models/saved
ML_RETRAIN_INTERVAL_HOURS=12
ML_MIN_SAMPLES_FOR_TRAINING=10

# Seuils anomalies (BF15)
ML_ANOMALY_CONTAMINATION=0.05
ML_ANOMALY_Z_SCORE_THRESHOLD=3.0

# Seuils risque (BF16)
ML_RISK_HIGH_THRESHOLD=0.7
ML_RISK_MEDIUM_THRESHOLD=0.4

# Clustering erreurs (BF17)
ML_CLUSTER_N_CLUSTERS=8
ML_CLUSTER_MIN_SAMPLES=3


# ┌─────────────────────────────────────────────────────────────┐
# │  CHAT SERVICE                                               │
# └─────────────────────────────────────────────────────────────┘
CHAT_WS_PATH=/ws/chat
CHAT_MAX_HISTORY=200
CHAT_MAX_FILE_SIZE=20MB


# ┌─────────────────────────────────────────────────────────────┐
# │  WORKFLOW DECLARATION SERVICE                               │
# └─────────────────────────────────────────────────────────────┘
WORKFLOW_MAX_FILE_SIZE=10MB
WORKFLOW_UPLOAD_DIR=uploads/templates


# ┌─────────────────────────────────────────────────────────────┐
# │  MONITORING — GRAFANA                                       │
# └─────────────────────────────────────────────────────────────┘
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=wifak2024
